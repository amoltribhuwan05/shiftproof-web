{
  "permissions": {
    "allow": [
      "Bash(gh repo *)",
      "Bash(npm list *)",
      "Bash(~/.local/bin/gh label *)",
      "Bash(~/.local/bin/gh issue *)",
      "Bash(python3 -c \"import json,sys; issues=json.load\\(sys.stdin\\); print\\(f'Total issues: {len\\(issues\\)}'\\); [print\\(f'  #{i[\\\\\"number\\\\\"]} {i[\\\\\"title\\\\\"]}'\\) for i in sorted\\(issues, key=lambda x: x['number']\\)]\")"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph status --json",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update --skip-flows",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
